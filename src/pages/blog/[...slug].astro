---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import CTA from "../../components/CTA.astro";
import { TAX_INFO } from "../../data/taxinfo";

const categoryLabels: Record<string, string> = {
  chwideuk: "취득세",
  yangdo: "양도세",
  jeungyeo: "증여세",
  sangsok: "상속세",
  etc: "기타",
};

export async function getStaticPaths() {
  const allPosts = await getCollection("blog");
  const sorted = allPosts.sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
  );

  return sorted.map((post) => {
    const sameCat = sorted.filter(
      (p) => p.id !== post.id && p.data.category === post.data.category
    );
    const related =
      sameCat.length > 0
        ? sameCat.slice(0, 4)
        : sorted.filter((p) => p.id !== post.id).slice(0, 4);

    return {
      params: { slug: post.id },
      props: { post, relatedPosts: related },
    };
  });
}

const { post, relatedPosts } = Astro.props;
const { Content } = await render(post);
const catLabel = categoryLabels[post.data.category] ?? post.data.category;
const typeLabel = post.data.type === "case" ? "사례" : post.data.type === "column" ? "칼럼" : null;
const taxInfo = TAX_INFO[post.data.category];
---
<Base title={post.data.title}>
  <main class="layout">
    <article class="card">
      <div class="meta">
        <span class={`badge cat-${post.data.category}`}>{catLabel}</span>
        {typeLabel && <span class="badge-type">{typeLabel}</span>}
        <time>{post.data.date}</time>
      </div>
      <h1 class="title">{post.data.title}</h1>
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="tags">
          {post.data.tags.map((tag: string) => (
            <a href={`/tags/${tag}/`} class="tag"># {tag}</a>
          ))}
        </div>
      )}
      <hr class="divider" />
      <div class="body">
        <Content />
      </div>
    </article>

    <aside class="sidebar">
      <form class="sidebar-search" action="/search/" method="get">
        <p class="sidebar-title">키워드로 찾기</p>
        <div class="search-input-wrap">
          <input type="text" name="q" placeholder="검색어 입력" class="search-input" />
          <button type="submit" class="search-btn" aria-label="검색">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </button>
        </div>
      </form>

      <div class="sidebar-taxinfo">
        <p class="sidebar-title">{catLabel} 한눈에</p>
        {taxInfo ? (
          <>
            <table class="si-table">
              <thead><tr><th>과세표준</th><th>세율</th><th>누진공제</th></tr></thead>
              <tbody>
                {taxInfo.rates.map((r) => (
                  <tr><td>{r.bracket}</td><td>{r.rate}</td><td>{r.deduction}</td></tr>
                ))}
              </tbody>
            </table>

            <p class="si-sub">증여재산공제 (10년간)</p>
            <table class="si-table">
              <thead><tr><th>증여자</th><th>공제한도</th></tr></thead>
              <tbody>
                {taxInfo.exemptions.map((e) => (
                  <tr><td>{e.relation}</td><td>{e.limit}</td></tr>
                ))}
              </tbody>
            </table>
            {taxInfo.exemptionNote && <p class="si-note">{taxInfo.exemptionNote}</p>}

            <div class="si-footer">
              <p>신고기한: {taxInfo.filingDeadline}</p>
              <p>신고·납부: {taxInfo.filingPerson}</p>
            </div>
          </>
        ) : (
          <p class="si-placeholder">정리 중입니다</p>
        )}
      </div>

      {relatedPosts.length > 0 && (
        <div class="sidebar-related">
          <p class="sidebar-title">{catLabel} 글 더보기</p>
          <ul>
            {relatedPosts.map((rp: any) => (
              <li><a href={`/blog/${rp.id}/`}>{rp.data.title}</a></li>
            ))}
          </ul>
        </div>
      )}
      <div class="sidebar-cta">
        <p class="cta-label">상담이 필요하세요?</p>
        <a href="https://pf.kakao.com/_dcihX/chat" target="_blank" rel="noopener" class="cta-btn">
          카카오톡 상담
        </a>
      </div>
    </aside>
  </main>

  <div class="bottom-area">
    <CTA />
    <div class="back-wrap">
      <a href="/" class="back">&larr; 목록으로</a>
    </div>
  </div>
</Base>

<style>
  /* ── Layout ── */
  .layout {
    max-width: 1080px;
    margin: 0 auto;
    padding: 2rem 1.5rem 0;
    display: flex;
    gap: 2rem;
    align-items: flex-start;
    overflow-x: hidden;
  }

  /* ── Article Card ── */
  .card {
    flex: 1;
    min-width: 0;
    max-width: 100%;
    background: #fff;
    border-radius: 12px;
    border: 1px solid #E2E8F0;
    padding: 2.5rem;
    overflow-x: hidden;
    box-shadow: 0 1px 3px 0 rgba(0,0,0,0.05);
  }

  /* ── Meta ── */
  .meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1rem;
  }
  .badge {
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
  }
  .cat-chwideuk { background: #4A6FA5; color: #fff; }
  .cat-yangdo { background: var(--dark-brown); color: var(--cream); }
  .cat-jeungyeo { background: var(--terracotta); color: #fff; }
  .cat-sangsok { background: #2D6A4F; color: #fff; }
  .cat-etc { background: #64748B; color: #fff; }
  .badge-type {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.15rem 0.45rem;
    border-radius: 3px;
    border: 1.2px solid var(--dark-brown);
    color: var(--dark-brown);
  }
  time {
    font-size: 0.8rem;
    color: #94A3B8;
  }

  /* ── Tags ── */
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }
  .tag {
    display: inline-block;
    background: #F1F5F9;
    color: var(--dark-brown);
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.25rem 0.65rem;
    border-radius: 20px;
    transition: background 0.15s;
  }
  .tag:hover {
    background: #E2E8F0;
  }

  /* ── Title & Divider ── */
  .title {
    font-family: 'Noto Serif KR', serif;
    font-size: 1.7rem;
    font-weight: 700;
    color: var(--dark-brown);
    line-height: 1.45;
    margin-bottom: 1rem;
  }
  .divider {
    border: none;
    height: 1px;
    background: #E2E8F0;
    margin-bottom: 2rem;
  }

  /* ── Body Typography ── */
  .body {
    font-size: 0.95rem;
    line-height: 1.85;
    color: #334155;
    counter-reset: h2counter;
  }
  .body :global(h2) {
    font-family: 'Noto Serif KR', serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--dark-brown);
    margin: 3rem 0 0.75rem;
    padding: 0.75rem 1rem 0.75rem 1rem;
    background: #EFF4F9;
    border-left: 4px solid #0B4171;
    border-radius: 0 8px 8px 0;
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    counter-increment: h2counter;
  }
  .body :global(h2)::before {
    content: counter(h2counter);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.5rem;
    height: 1.5rem;
    margin-top: 0.1em;
    background: #0B4171;
    color: #fff;
    font-family: 'Pretendard', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    border-radius: 6px;
    flex-shrink: 0;
  }
  .body :global(h3) {
    font-size: 1.06rem;
    font-weight: 700;
    color: var(--dark-brown);
    margin: 2.5rem 0 1rem;
    padding: 0.5rem 0.75rem;
    background: #F1F5F9;
    border-left: 4px solid var(--dark-brown);
    border-radius: 0 6px 6px 0;
  }
  .body :global(p) {
    margin-bottom: 1rem;
  }
  .body :global(ul), .body :global(ol) {
    margin: 0.5rem 0 1rem 1.25rem;
  }
  .body :global(li) {
    margin-bottom: 0.3rem;
  }
  .body :global(strong) {
    color: var(--dark-brown);
    font-weight: 700;
  }

  /* ── Table ── */
  .body :global(.table-wrap) {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin: 1.25rem 0;
    border-radius: 8px;
    border: 1px solid #E2E8F0;
    max-width: 100%;
  }
  .body :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
  }
  .body :global(th) {
    background: var(--dark-brown);
    color: var(--cream);
    font-weight: 700;
    padding: 0.65rem 1rem;
    text-align: left;
    white-space: nowrap;
  }
  .body :global(td) {
    padding: 0.6rem 1rem;
    border-top: 1px solid #E2E8F0;
  }
  .body :global(tr:nth-child(even) td) {
    background: #F8FAFC;
  }

  /* ── Blockquote ── */
  .body :global(blockquote) {
    background: #F1F5F9;
    border-left: 3px solid var(--terracotta);
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
    border-radius: 0 8px 8px 0;
    font-size: 0.9rem;
    color: #64748B;
  }

  /* ── Sidebar Search ── */
  .sidebar-search {
    background: #fff;
    border-radius: 12px;
    border: 1px solid #E2E8F0;
    padding: 1.25rem;
  }
  .search-input-wrap {
    display: flex;
    gap: 0;
  }
  .search-input {
    flex: 1;
    min-width: 0;
    border: 1.5px solid #E2E8F0;
    border-right: none;
    border-radius: 8px 0 0 8px;
    padding: 0.5rem 0.65rem;
    font-size: 0.8rem;
    font-family: 'Pretendard', sans-serif;
    background: #F8FAFC;
    color: var(--dark-brown);
    outline: none;
  }
  .search-input:focus {
    border-color: var(--terracotta);
  }
  .search-btn {
    background: var(--dark-brown);
    border: none;
    border-radius: 0 8px 8px 0;
    padding: 0 0.6rem;
    color: var(--cream);
    cursor: pointer;
    display: flex;
    align-items: center;
  }

  /* ── Sidebar Tax Info ── */
  .sidebar-taxinfo {
    background: #fff;
    border-radius: 12px;
    border: 1px solid #E2E8F0;
    padding: 1.25rem;
  }
  .si-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .si-table th {
    background: #F1F5F9;
    color: var(--dark-brown);
    font-weight: 700;
    padding: 0.35rem 0.5rem;
    text-align: left;
    white-space: nowrap;
  }
  .si-table td {
    padding: 0.3rem 0.5rem;
    border-top: 1px solid #E2E8F0;
    white-space: nowrap;
  }
  .si-sub {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--dark-brown);
    margin-bottom: 0.35rem;
  }
  .si-note {
    font-size: 0.7rem;
    color: #94A3B8;
    margin-bottom: 0.75rem;
  }
  .si-footer {
    border-top: 1px solid #E2E8F0;
    padding-top: 0.6rem;
  }
  .si-footer p {
    font-size: 0.7rem;
    color: #94A3B8;
    line-height: 1.6;
  }
  .si-placeholder {
    font-size: 0.8rem;
    color: #94A3B8;
    text-align: center;
    padding: 1rem 0;
  }

  /* ── Sidebar ── */
  .sidebar {
    width: 240px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: sticky;
    top: 80px;
    align-self: flex-start;
  }
  .sidebar-related {
    background: #fff;
    border-radius: 12px;
    border: 1px solid #E2E8F0;
    padding: 1.25rem;
  }
  .sidebar-title {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--terracotta);
    margin-bottom: 0.75rem;
  }
  .sidebar-related ul {
    list-style: none;
  }
  .sidebar-related li {
    border-top: 1px solid #E2E8F0;
    padding: 0.6rem 0;
  }
  .sidebar-related li:first-child {
    border-top: none;
    padding-top: 0;
  }
  .sidebar-related li:last-child {
    padding-bottom: 0;
  }
  .sidebar-related a {
    font-size: 0.85rem;
    line-height: 1.5;
    display: block;
    transition: color 0.15s;
  }
  .sidebar-related a:hover {
    color: var(--terracotta);
  }
  .sidebar-cta {
    background: var(--dark-brown);
    border-radius: 12px;
    padding: 1.5rem 1.25rem;
    text-align: center;
  }
  .cta-label {
    font-family: 'Noto Serif KR', serif;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--cream);
    margin-bottom: 0.75rem;
  }
  .cta-btn {
    display: inline-block;
    background: #FEE500;
    color: #191919;
    font-weight: 700;
    font-size: 0.85rem;
    padding: 0.55rem 1.25rem;
    border-radius: 8px;
    transition: opacity 0.2s;
  }
  .cta-btn:hover { opacity: 0.85; }

  /* ── Bottom CTA + Back ── */
  .bottom-area {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
  }
  .back-wrap {
    margin-top: 2rem;
    text-align: center;
  }
  .back {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--terracotta);
  }

  /* ── Mobile ── */
  @media (max-width: 1024px) {
    .layout {
      flex-direction: column;
    }
    .sidebar {
      width: 100%;
      position: static;
      flex-direction: row;
      flex-wrap: wrap;
    }
    .sidebar-related,
    .sidebar-cta {
      flex: 1;
      min-width: 240px;
    }
    .card {
      padding: 1.75rem;
    }
    .title {
      font-size: 1.45rem;
    }
  }

  @media (max-width: 640px) {
    .sidebar {
      flex-direction: column;
    }
    .sidebar-related,
    .sidebar-cta {
      min-width: auto;
    }
    .card {
      padding: 1.25rem;
    }
  }
</style>

<script>
  // Wrap tables in scrollable container
  document.querySelectorAll('.body table').forEach((table) => {
    const wrap = document.createElement('div');
    wrap.className = 'table-wrap';
    table.parentNode!.insertBefore(wrap, table);
    wrap.appendChild(table);
  });
</script>
