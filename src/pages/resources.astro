---
import Base from "../layouts/Base.astro";
---
<Base title="서식·자료">
  <main class="main">
    <h1 class="page-title">서식 · 자료</h1>
    <p class="placeholder">준비 중입니다.</p>
  </main>
</Base>

<style>
  .main {
    max-width: 720px;
    margin: 0 auto;
    padding: 4rem 1.5rem;
  }
  .page-title {
    font-family: 'Noto Serif KR', serif;
    font-size: 1.6rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
  }
  .placeholder {
    color: #999;
    font-size: 0.9rem;
  }
</style>
