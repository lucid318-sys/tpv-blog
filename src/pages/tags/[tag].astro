---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  const tagMap = new Map<string, typeof posts>();

  for (const post of posts) {
    for (const tag of post.data.tags ?? []) {
      if (!tagMap.has(tag)) tagMap.set(tag, []);
      tagMap.get(tag)!.push(post);
    }
  }

  return [...tagMap.entries()].map(([tag, tagPosts]) => ({
    params: { tag },
    props: {
      tag,
      posts: tagPosts.sort(
        (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
      ),
    },
  }));
}

const { tag, posts } = Astro.props;
---
<Base title={`# ${tag}`}>
  <main class="layout">
    <div class="content">
      <h1 class="page-title"># {tag} <span class="count">· {posts.length}건</span></h1>
      <div class="list">
        {posts.map((post: any) => (
          <PostCard
            slug={post.id}
            title={post.data.title}
            date={post.data.date}
            category={post.data.category}
            type={post.data.type}
            summary={post.data.summary}
          />
        ))}
      </div>
    </div>

    <aside class="sidebar">
      <div class="sidebar-cta">
        <p class="cta-label">상담이 필요하세요?</p>
        <a href="https://pf.kakao.com/_dcihX/chat" target="_blank" rel="noopener" class="cta-btn">
          카카오톡 상담
        </a>
      </div>
    </aside>
  </main>
</Base>

<style>
  .layout {
    max-width: 1080px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
    display: flex;
    gap: 2rem;
    align-items: flex-start;
  }
  .content {
    flex: 1;
    min-width: 0;
  }
  .page-title {
    font-family: 'Noto Serif KR', serif;
    font-size: 1.6rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
  }
  .count {
    font-size: 1rem;
    font-weight: 400;
    color: #999;
  }
  .list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .sidebar {
    width: 240px;
    flex-shrink: 0;
    position: sticky;
    top: 80px;
    align-self: flex-start;
  }
  .sidebar-cta {
    background: var(--dark-brown);
    border-radius: 12px;
    padding: 1.5rem 1.25rem;
    text-align: center;
  }
  .cta-label {
    font-family: 'Noto Serif KR', serif;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--cream);
    margin-bottom: 0.75rem;
  }
  .cta-btn {
    display: inline-block;
    background: var(--terracotta);
    color: #fff;
    font-weight: 700;
    font-size: 0.85rem;
    padding: 0.55rem 1.25rem;
    border-radius: 8px;
    transition: opacity 0.2s;
  }
  .cta-btn:hover { opacity: 0.85; }

  @media (max-width: 1024px) {
    .layout { flex-direction: column; }
    .sidebar { width: 100%; position: static; }
  }
</style>
