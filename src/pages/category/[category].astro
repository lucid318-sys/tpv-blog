---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";
import { TAX_INFO } from "../../data/taxinfo";

export async function getStaticPaths() {
  const categories: Record<string, string> = {
    chwideuk: "취득세",
    yangdo: "양도소득세",
    jeungyeo: "증여세",
    sangsok: "상속세",
    etc: "기타",
  };
  const posts = await getCollection("blog");
  return Object.keys(categories).map((cat) => ({
    params: { category: cat },
    props: {
      catSlug: cat,
      label: categories[cat],
      posts: posts
        .filter((p) => p.data.category === cat)
        .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()),
    },
  }));
}

const { catSlug, label, posts } = Astro.props;
const taxInfo = TAX_INFO[catSlug];
---
<Base title={`${label} — 세금 이야기`}>
  <main class="layout">
    <div class="content">
      <h1 class="page-title">{label}</h1>
      <div class="list">
        {posts.length === 0 ? (
          <p class="empty">아직 작성된 글이 없습니다.</p>
        ) : (
          posts.map((post: any) => (
            <PostCard
              slug={post.id}
              title={post.data.title}
              date={post.data.date}
              category={post.data.category}
              type={post.data.type}
              summary={post.data.summary}
            />
          ))
        )}
      </div>
    </div>

    <aside class="sidebar">
      <form class="sidebar-search" action="/search/" method="get">
        <p class="sidebar-title">키워드로 찾기</p>
        <div class="search-input-wrap">
          <input type="text" name="q" placeholder="검색어 입력" class="search-input" />
          <button type="submit" class="search-btn" aria-label="검색">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </button>
        </div>
      </form>

      <div class="sidebar-taxinfo">
        <p class="sidebar-title">{label} 한눈에</p>
        {taxInfo ? (
          <>
            <table class="si-table">
              <thead><tr><th>과세표준</th><th>세율</th><th>누진공제</th></tr></thead>
              <tbody>
                {taxInfo.rates.map((r) => (
                  <tr><td>{r.bracket}</td><td>{r.rate}</td><td>{r.deduction}</td></tr>
                ))}
              </tbody>
            </table>

            <p class="si-sub">증여재산공제 (10년간)</p>
            <table class="si-table">
              <thead><tr><th>증여자</th><th>공제한도</th></tr></thead>
              <tbody>
                {taxInfo.exemptions.map((e) => (
                  <tr><td>{e.relation}</td><td>{e.limit}</td></tr>
                ))}
              </tbody>
            </table>
            {taxInfo.exemptionNote && <p class="si-note">{taxInfo.exemptionNote}</p>}

            <div class="si-footer">
              <p>신고기한: {taxInfo.filingDeadline}</p>
              <p>신고·납부: {taxInfo.filingPerson}</p>
            </div>
          </>
        ) : (
          <p class="si-placeholder">정리 중입니다</p>
        )}
      </div>

      <div class="sidebar-cta">
        <p class="cta-label">상담이 필요하세요?</p>
        <a href="https://pf.kakao.com/_dcihX/chat" target="_blank" rel="noopener" class="cta-btn">
          카카오톡 상담
        </a>
      </div>
    </aside>
  </main>
</Base>

<style>
  .layout {
    max-width: 1080px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
    display: flex;
    gap: 2rem;
    align-items: flex-start;
  }
  .content {
    flex: 1;
    min-width: 0;
  }
  .page-title {
    font-family: 'Noto Serif KR', serif;
    font-size: 1.6rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
  }
  .list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .empty {
    text-align: center;
    color: #94A3B8;
    padding: 3rem 0;
  }

  /* ── Sidebar ── */
  .sidebar {
    width: 240px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: sticky;
    top: 80px;
    align-self: flex-start;
  }

  /* ── Sidebar Search ── */
  .sidebar-search {
    background: #fff;
    border-radius: 12px;
    border: 1px solid #E2E8F0;
    padding: 1.25rem;
  }
  .search-input-wrap {
    display: flex;
    gap: 0;
  }
  .search-input {
    flex: 1;
    min-width: 0;
    border: 1.5px solid #E2E8F0;
    border-right: none;
    border-radius: 8px 0 0 8px;
    padding: 0.5rem 0.65rem;
    font-size: 0.8rem;
    font-family: 'Pretendard', sans-serif;
    background: #F8FAFC;
    color: var(--dark-brown);
    outline: none;
  }
  .search-input:focus {
    border-color: var(--terracotta);
  }
  .search-btn {
    background: var(--dark-brown);
    border: none;
    border-radius: 0 8px 8px 0;
    padding: 0 0.6rem;
    color: var(--cream);
    cursor: pointer;
    display: flex;
    align-items: center;
  }

  /* ── Tax Info Card ── */
  .sidebar-taxinfo {
    background: #fff;
    border-radius: 12px;
    border: 1px solid #E2E8F0;
    padding: 1.25rem;
  }
  .sidebar-title {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--terracotta);
    margin-bottom: 0.75rem;
  }
  .si-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .si-table th {
    background: #F1F5F9;
    color: var(--dark-brown);
    font-weight: 700;
    padding: 0.35rem 0.5rem;
    text-align: left;
    white-space: nowrap;
  }
  .si-table td {
    padding: 0.3rem 0.5rem;
    border-top: 1px solid #E2E8F0;
    white-space: nowrap;
  }
  .si-sub {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--dark-brown);
    margin-bottom: 0.35rem;
  }
  .si-note {
    font-size: 0.7rem;
    color: #94A3B8;
    margin-bottom: 0.75rem;
  }
  .si-footer {
    border-top: 1px solid #E2E8F0;
    padding-top: 0.6rem;
  }
  .si-footer p {
    font-size: 0.7rem;
    color: #94A3B8;
    line-height: 1.6;
  }
  .si-placeholder {
    font-size: 0.8rem;
    color: #94A3B8;
    text-align: center;
    padding: 1rem 0;
  }

  /* ── CTA Card ── */
  .sidebar-cta {
    background: var(--dark-brown);
    border-radius: 12px;
    padding: 1.5rem 1.25rem;
    text-align: center;
  }
  .cta-label {
    font-family: 'Noto Serif KR', serif;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--cream);
    margin-bottom: 0.75rem;
  }
  .cta-btn {
    display: inline-block;
    background: #FEE500;
    color: #191919;
    font-weight: 700;
    font-size: 0.85rem;
    padding: 0.55rem 1.25rem;
    border-radius: 8px;
    transition: opacity 0.2s;
  }
  .cta-btn:hover { opacity: 0.85; }

  /* ── Mobile ── */
  @media (max-width: 1024px) {
    .layout {
      flex-direction: column;
    }
    .sidebar {
      width: 100%;
      position: static;
      flex-direction: row;
      flex-wrap: wrap;
    }
    .sidebar-taxinfo,
    .sidebar-cta {
      flex: 1;
      min-width: 240px;
    }
  }
  @media (max-width: 640px) {
    .sidebar {
      flex-direction: column;
    }
    .sidebar-taxinfo,
    .sidebar-cta {
      min-width: auto;
    }
  }
</style>
