<script define:vars={{ areaDataJson }}>
  // 규제지역 빠른 조회 위젯
  const areas = JSON.parse(areaDataJson);
  const SIDO_ALIAS = {
    '서울':'서울특별시','부산':'부산광역시','대구':'대구광역시','인천':'인천광역시',
    '광주':'광주광역시','대전':'대전광역시','울산':'울산광역시','세종':'세종특별자치시',
    '경기':'경기도','강원':'강원도','충북':'충청북도','충남':'충청남도',
    '전북':'전라북도','전남':'전라남도','경북':'경상북도','경남':'경상남도',
    '제주':'제주특별자치도',
  };

  const input = document.getElementById('reg-input');
  const pillsContainer = document.getElementById('reg-pills');

  input.addEventListener('input', () => {
    const raw = input.value.trim();
    pillsContainer.innerHTML = '';
    if (!raw) return;

    const queries = [raw];
    if (SIDO_ALIAS[raw]) queries.push(SIDO_ALIAS[raw]);
    // 역방향: 풀네임 → 축약형 매칭도 커버
    for (const [short, full] of Object.entries(SIDO_ALIAS)) {
      if (raw === full) queries.push(short);
    }

    const seen = new Set();
    const matches = [];
    for (const a of areas) {
      const label = a.sido + ' ' + a.region;
      if (seen.has(label)) continue;
      const hit = queries.some(q => a.sido.includes(q) || a.region.includes(q));
      if (hit) {
        seen.add(label);
        matches.push(a);
      }
      if (matches.length >= 5) break;
    }

    // 현재 지정중인 지역 우선 정렬
    matches.sort((a, b) => (b.active ? 1 : 0) - (a.active ? 1 : 0));

    for (const m of matches) {
      const pill = document.createElement('a');
      pill.className = 'reg-pill ' + (m.active ? 'active-area' : 'lifted-area');
      pill.textContent = m.sido + ' ' + m.region;
      pill.href = '/resources/regulated-areas/?q=' + encodeURIComponent(m.region);
      pillsContainer.appendChild(pill);
    }
  });
</script>
