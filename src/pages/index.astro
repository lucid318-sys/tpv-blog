---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import { regulationPeriods } from "../data/regulatedAreaHistory";

const posts = (await getCollection("blog"))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const categoryLabels: Record<string, string> = {
  chwideuk: "취득세",
  yangdo: "양도세",
  sangsok: "상속세",
  jeungyeo: "증여세",
  etc: "기타",
};

// 규제지역 위젯용 경량 데이터: sido+region 유니크 목록 + 현재 지정 여부
const seen = new Set<string>();
const areaList: { sido: string; region: string; active: boolean }[] = [];
for (const p of regulationPeriods) {
  const key = `${p.sido}|${p.region}`;
  if (seen.has(key)) {
    // 이미 있으면 active만 갱신 (하나라도 지정중이면 active)
    if (!p.lifted) {
      const existing = areaList.find(a => a.sido === p.sido && a.region === p.region);
      if (existing) existing.active = true;
    }
    continue;
  }
  seen.add(key);
  areaList.push({ sido: p.sido, region: p.region, active: !p.lifted });
}
const areaDataJson = JSON.stringify(areaList);
---
