---
import Base from "../layouts/Base.astro";
---
<Base title="검색">
  <main class="main">
    <h1 class="page-title">검색</h1>
    <div class="search-bar">
      <input type="text" id="q" placeholder="검색어를 입력하세요" class="input" autofocus />
    </div>
    <div id="results" class="results"></div>
    <p id="empty" class="empty" style="display:none;">검색 결과가 없습니다</p>
    <p id="initial" class="initial">검색어를 입력하면 제목, 본문, 태그에서 찾아드립니다.</p>
  </main>
</Base>

<style>
  .main {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }
  .page-title {
    font-family: 'Noto Serif KR', serif;
    font-size: 1.6rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
  }
  .search-bar {
    margin-bottom: 2rem;
  }
  .input {
    width: 100%;
    padding: 0.85rem 1rem;
    font-size: 1rem;
    font-family: 'Pretendard', sans-serif;
    border: 2px solid #E2E8F0;
    border-radius: 10px;
    background: #fff;
    color: var(--dark-brown);
    outline: none;
    transition: border-color 0.15s;
  }
  .input:focus {
    border-color: var(--terracotta);
  }
  .results {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .empty, .initial {
    text-align: center;
    color: #94A3B8;
    padding: 2rem 0;
    font-size: 0.9rem;
  }
</style>

<script>
  const CAT_LABELS: Record<string, string> = {
    chwideuk: "취득세", yangdo: "양도세", jeungyeo: "증여세",
    sangsok: "상속세", etc: "기타",
  };
  const CAT_COLORS: Record<string, string> = {
    chwideuk: "#4A6FA5", yangdo: "#0B4171", jeungyeo: "#2563EB",
    sangsok: "#2D6A4F", etc: "#64748B",
  };
  const CAT_TEXT: Record<string, string> = {
    chwideuk: "#fff", yangdo: "#F8FAFC", jeungyeo: "#fff",
    sangsok: "#fff", etc: "#fff",
  };

  interface SearchItem {
    slug: string;
    title: string;
    summary: string;
    category: string;
    type: string | null;
    tags: string[];
    body: string;
  }

  let data: SearchItem[] = [];

  async function init() {
    const res = await fetch("/search-index.json");
    data = await res.json();

    const params = new URLSearchParams(window.location.search);
    const q = params.get("q");
    if (q) {
      (document.getElementById("q") as HTMLInputElement).value = q;
      search(q);
    }
  }

  function search(query: string) {
    const q = query.trim().toLowerCase();
    const results = document.getElementById("results")!;
    const empty = document.getElementById("empty")!;
    const initial = document.getElementById("initial")!;

    initial.style.display = "none";

    if (!q) {
      results.innerHTML = "";
      empty.style.display = "none";
      initial.style.display = "";
      return;
    }

    const matches = data.filter((item) => {
      const haystack = [item.title, item.summary, item.body, ...item.tags].join(" ").toLowerCase();
      return haystack.includes(q);
    });

    if (matches.length === 0) {
      results.innerHTML = "";
      empty.style.display = "";
      return;
    }

    empty.style.display = "none";
    results.innerHTML = matches
      .map((item) => {
        const bg = CAT_COLORS[item.category] ?? "#888";
        const tc = CAT_TEXT[item.category] ?? "#fff";
        const label = CAT_LABELS[item.category] ?? item.category;
        return `<a href="/blog/${item.slug}/" class="result-card">
          <div class="result-meta">
            <span class="result-badge" style="background:${bg};color:${tc}">${label}</span>
          </div>
          <p class="result-title">${item.title}</p>
          <p class="result-summary">${item.summary}</p>
        </a>`;
      })
      .join("");
  }

  document.getElementById("q")!.addEventListener("input", (e) => {
    search((e.target as HTMLInputElement).value);
  });

  init();
</script>

<style is:global>
  .result-card {
    display: block;
    background: #fff;
    border-radius: 12px;
    padding: 1.25rem;
    box-shadow: 0 1px 3px 0 rgba(0,0,0,0.05);
    transition: box-shadow 0.2s;
  }
  .result-card:hover {
    box-shadow: 0 4px 20px rgba(0,0,0,0.05);
  }
  .result-meta {
    margin-bottom: 0.5rem;
  }
  .result-badge {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
  }
  .result-title {
    font-family: 'Noto Serif KR', serif;
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
    line-height: 1.5;
    color: #0F172A;
  }
  .result-summary {
    font-size: 0.85rem;
    color: #64748B;
    line-height: 1.6;
  }
</style>
