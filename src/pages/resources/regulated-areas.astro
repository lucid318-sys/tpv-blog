---
import Base from "../../layouts/Base.astro";
import { ADJUSTED_AREAS, SPECULATION_AREAS, REFERENCE_DATE } from "../../data/regulatedAreas";
import {
  regulationPeriods, officialNotices, toTimelineEvents,
  REGULATION_TYPE_LABEL, HISTORY_BASE_DATE, SPECULATION_BASE_DATE,
  LEGAL_NOTES,
  type RegulationEvent, type RegulationType,
} from "../../data/regulatedAreaHistory";

// ── 타임라인 그룹핑 (speculation 제외) ──
const events = toTimelineEvents(regulationPeriods.filter(p => p.type !== 'speculation'));
interface MatchedNotice { id: string; file?: string }
interface TimelineGroup {
  date: string;
  kind: '지정' | '해제';
  type: RegulationType;
  typeLabel: string;
  regions: { sido: string; region: string; scope?: string }[];
  notices: MatchedNotice[];
}
const groupMap = new Map<string, TimelineGroup>();
for (const ev of events) {
  const key = `${ev.date}|${ev.type}|${ev.kind}`;
  if (!groupMap.has(key)) {
    groupMap.set(key, {
      date: ev.date,
      kind: ev.kind,
      type: ev.type,
      typeLabel: REGULATION_TYPE_LABEL[ev.type],
      regions: [],
      notices: [],
    });
  }
  groupMap.get(key)!.regions.push({ sido: ev.sido, region: ev.region, scope: ev.scope });
}

// 그룹별 공고 매칭: 원본 레코드에서 notice 문자열 수집 → 공고번호 추출 → officialNotices 매칭
const noticeIdRegex = /제(\d+-\d+)호/g;
const noticeById = new Map(officialNotices.map(n => [n.id, n]));

for (const [key, group] of groupMap) {
  const noticeStrings = new Set<string>();
  // 이 그룹에 해당하는 원본 레코드 찾기
  const matchingPeriods = regulationPeriods.filter(p =>
    p.type === group.type && p.type !== 'speculation' &&
    ((group.kind === '지정' && p.designated === group.date) ||
     (group.kind === '해제' && p.lifted === group.date))
  );
  for (const p of matchingPeriods) {
    const noticeField = group.kind === '지정' ? p.designationNotice : p.liftNotice;
    if (noticeField) noticeStrings.add(noticeField);
  }

  // 공고번호 추출 + officialNotices 매칭
  const seenIds = new Set<string>();
  for (const str of noticeStrings) {
    let match;
    const re = new RegExp(noticeIdRegex.source, 'g');
    while ((match = re.exec(str)) !== null) {
      const num = match[1]; // e.g. "2026-882"
      for (const [id, notice] of noticeById) {
        if (id.includes(num) && !seenIds.has(id)) {
          seenIds.add(id);
          group.notices.push({ id, file: notice.file });
        }
      }
    }
  }
}

const timelineGroups = [...groupMap.values()];

// 시도별로 묶어 요약 텍스트 생성
function summarizeRegions(regions: { sido: string; region: string; scope?: string }[]): { sido: string; names: string }[] {
  const byDo = new Map<string, string[]>();
  for (const r of regions) {
    if (!byDo.has(r.sido)) byDo.set(r.sido, []);
    byDo.get(r.sido)!.push(r.region + (r.scope ? `(${r.scope})` : ''));
  }
  return [...byDo.entries()].map(([sido, names]) => ({ sido, names: names.join(', ') }));
}

// 공고 날짜 내림차순
const sortedNotices = [...officialNotices].sort((a, b) => b.date.localeCompare(a.date));

// 기준일 포맷
function fmtDate(d: string) { return d.split('-').map((s, i) => i === 0 ? s : String(Number(s))).join('.'); }

// 클라이언트에 전달할 데이터 (인라인 JSON)
const clientPeriods = regulationPeriods.map(p => ({
  type: p.type, sido: p.sido, region: p.region,
  scope: p.scope, target: p.target,
  designated: p.designated, lifted: p.lifted,
  redesignation: p.redesignation, note: p.note,
  designationNotice: p.designationNotice, liftNotice: p.liftNotice,
  needsVerify: p.needsVerify,
}));
const clientNoticeMap: Record<string, { file?: string }> = {};
for (const n of officialNotices) {
  // 공고 ID에서 짧은 키 추출 (예: "제2025-1223호")
  clientNoticeMap[n.id] = { file: n.file };
}
---
<Base title="규제지역 조회">
  <main class="layout">
    <div class="content">
      <div class="header">
        <h1 class="page-title">규제지역 지정현황</h1>
        <span class="date-badge">{REFERENCE_DATE} 기준</span>
      </div>

      {/* ① 현재 지정현황 표 */}
      <section class="section">
        <h2 class="section-title">조정대상지역</h2>
        <div class="table-wrap">
          <table>
            <thead><tr><th>지역</th><th>구 · 시</th></tr></thead>
            <tbody>
              {ADJUSTED_AREAS.map((g) => (
                <tr>
                  <td class="region">{g.region}</td>
                  <td>{g.areas.join(", ")}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <section class="section">
        <h2 class="section-title">투기과열지구</h2>
        <div class="table-wrap">
          <table>
            <thead><tr><th>지역</th><th>구 · 시</th></tr></thead>
            <tbody>
              {SPECULATION_AREAS.map((g) => (
                <tr>
                  <td class="region">{g.region}</td>
                  <td>{g.areas.join(", ")}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      {/* ② 지역별 조회 */}
      <section class="section" id="region-search-section">
        <h2 class="section-title">지역별 조회</h2>
        <div class="region-search-wrap">
          <input type="text" id="region-search" class="region-search" placeholder="지역명 입력 (예: 강남, 화성, 세종)" />
        </div>
        <div id="region-results"></div>
        <p id="region-initial" class="region-initial">지역명을 입력하면 규제지역 지정·해제 이력을 조회합니다.</p>
        <p id="region-empty" class="region-empty" style="display:none;">검색 결과가 없습니다.</p>
      </section>

      {/* ③ 지정·해제 연혁 타임라인 */}
      <section class="section" id="section-timeline">
        <h2 class="section-title">지정 · 해제 연혁</h2>
        <div id="timeline">
          {timelineGroups.map((g, i) => {
            const summary = summarizeRegions(g.regions);
            const isDesignation = g.kind === '지정';
            return (
              <div
                class={`tl-card ${isDesignation ? 'tl-designation' : 'tl-lift'} ${i >= 4 ? 'tl-hidden' : ''}`}
                data-tl-idx={i}
              >
                <div class="tl-header">
                  <span class="tl-date">{fmtDate(g.date)}</span>
                  <span class={`tl-kind ${isDesignation ? 'kind-designation' : 'kind-lift'}`}>{g.kind}</span>
                  <span class={`tl-type reg-${g.type}`}>{g.typeLabel}</span>
                  <span class="tl-count">{g.regions.length}곳</span>
                </div>
                <div class="tl-regions">
                  {summary.map((s, si) => (
                    <p class={`tl-region-line ${si >= 3 ? 'tl-region-hidden' : ''}`}>
                      <strong>{s.sido}</strong> {s.names}
                    </p>
                  ))}
                  {summary.length > 3 && (
                    <button class="tl-expand-regions" data-action="expand-regions">+ {summary.length - 3}개 시도 더보기</button>
                  )}
                </div>
                {g.notices.length > 0 && (
                  <div class="tl-notices">
                    {g.notices.map((n) => {
                      const ext = n.file ? n.file.split('.').pop()?.toUpperCase() : null;
                      return n.file ? (
                        <a href={n.file} target="_blank" rel="noopener" class="tl-notice-link" {...(n.file?.endsWith('.hwp') ? { download: '' } : {})}>
                          {n.id}
                          {ext && <span class={`notice-ext ext-${ext.toLowerCase()}`}>{ext}</span>}
                        </a>
                      ) : (
                        <span class="tl-notice-text">{n.id}</span>
                      );
                    })}
                  </div>
                )}
              </div>
            );
          })}
        </div>
        {timelineGroups.length > 4 && (
          <button class="btn-more" id="btn-timeline-more" data-total={timelineGroups.length} data-limit="4">
            전체 연혁 보기 ({timelineGroups.length - 4}건 더)
          </button>
        )}
      </section>

      {/* ④ 원본 공고 다운로드 */}
      <section class="section" id="section-notices">
        <h2 class="section-title">원본 공고 다운로드</h2>
        <div class="notice-list">
          {sortedNotices.map((n, i) => {
            const ext = n.file ? n.file.split('.').pop()?.toUpperCase() : null;
            return (
              <div class={`notice-row ${i >= 4 ? 'notice-hidden' : ''}`} title={n.summary}>
                <span class="notice-date">{fmtDate(n.date)}</span>
                <span class={`notice-reg reg-${n.type}`}>{REGULATION_TYPE_LABEL[n.type]}</span>
                <span class={`notice-kind nk-${n.kind === '지정' ? 'des' : n.kind === '해제' ? 'lift' : n.kind === '정정' ? 'fix' : 'both'}`}>{n.kind}</span>
                {n.file ? (
                  <a href={n.file} target="_blank" rel="noopener" class="notice-link" {...(n.file?.endsWith('.hwp') ? { download: '' } : {})}>{n.id}</a>
                ) : (
                  <span class="notice-unavailable">{n.id}</span>
                )}
                {ext && <span class={`notice-ext ext-${ext.toLowerCase()}`}>{ext}</span>}
              </div>
            );
          })}
        </div>
        {sortedNotices.length > 4 && (
          <button class="btn-more" id="btn-notices-more" data-total={sortedNotices.length} data-limit="4">
            공고 전체 보기 ({sortedNotices.length - 4}건 더)
          </button>
        )}
      </section>

      {/* ⑤ 고지문구 */}
      <div class="legal-box">
        <p class="legal-basis">
          조정대상지역 · 투기과열지구: {fmtDate(HISTORY_BASE_DATE)} 기준 / 투기지역: {fmtDate(SPECULATION_BASE_DATE)} 기준
        </p>
        <p class="legal-source">출처: 국토교통부 공고 · etaxkorea 조세자료 정리</p>
        <ul class="legal-notes">
          {LEGAL_NOTES.map((note) => (
            <li>{note}</li>
          ))}
        </ul>
        <p class="legal-warn">본 자료는 참고용이며, 세무 판단 시 반드시 원문 공고를 확인하시기 바랍니다.</p>
      </div>

      <div class="back-wrap">
        <a href="/resources/" class="back">&larr; 서식 · 자료로 돌아가기</a>
      </div>
    </div>

    <aside class="sidebar">
      <form class="sidebar-search" action="/search/" method="get">
        <p class="sidebar-title">키워드로 찾기</p>
        <div class="search-input-wrap">
          <input type="text" name="q" placeholder="검색어 입력" class="search-input" />
          <button type="submit" class="search-btn" aria-label="검색">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </button>
        </div>
      </form>

      <div class="sidebar-cta">
        <p class="cta-label">상담이 필요하세요?</p>
        <a href="https://pf.kakao.com/_dcihX/chat" target="_blank" rel="noopener" class="cta-btn">
          카카오톡 상담
        </a>
      </div>
    </aside>
  </main>
</Base>

<style>
  /* ── Layout ── */
  .layout {
    max-width: 1080px;
    margin: 0 auto;
    padding: 2rem 1.5rem 0;
    display: flex;
    gap: 2rem;
    align-items: flex-start;
  }
  .content {
    flex: 1;
    min-width: 0;
  }
  .header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  .page-title {
    font-family: 'SUIT Variable', 'Pretendard', sans-serif;
    font-size: 1.6rem;
    font-weight: 700;
  }
  .date-badge {
    font-size: 0.75rem;
    font-weight: 700;
    background: var(--terracotta);
    color: #fff;
    padding: 0.25rem 0.65rem;
    border-radius: 20px;
  }

  .section { margin-bottom: 2.5rem; }
  .section-title {
    font-family: 'SUIT Variable', 'Pretendard', sans-serif;
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--dark-brown);
  }

  /* ── Table (현재 지정현황) ── */
  .table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-radius: 8px;
    border: 1px solid #e8e2d6;
    max-width: 100%;
  }
  table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
  th {
    background: var(--dark-brown);
    color: var(--cream);
    font-weight: 700;
    padding: 0.65rem 1rem;
    text-align: left;
    white-space: nowrap;
  }
  td { padding: 0.7rem 1rem; border-top: 1px solid #e8e2d6; line-height: 1.7; }
  tr:nth-child(even) td { background: #faf7f1; }
  .region { white-space: nowrap; font-weight: 700; }

  /* ── 타임라인 ── */
  .tl-card {
    background: #fff;
    border: 1px solid #eae4d8;
    border-radius: 10px;
    padding: 1rem 1.25rem;
    margin-bottom: 0.6rem;
    cursor: pointer;
    transition: box-shadow 0.15s;
  }
  .tl-card:hover { box-shadow: 0 2px 12px rgba(44,33,23,0.08); }
  .tl-designation { border-left: 4px solid #7B3B3B; }
  .tl-lift { border-left: 4px solid #64748B; }
  .tl-hidden { display: none; }
  .tl-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }
  .tl-date { font-size: 0.8rem; font-weight: 700; color: var(--dark-brown); }
  .tl-kind {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
  }
  .kind-designation { background: #F1E3E3; color: #7B3B3B; }
  .kind-lift { background: #F1F5F9; color: #64748B; }
  .tl-type {
    font-size: 0.68rem; font-weight: 700;
    padding: 0.1rem 0.4rem; border-radius: 4px;
  }
  .reg-adjustment { background: #F1E3E3; color: #7B3B3B; }
  .reg-overheated { background: #F9E8DC; color: #D4622B; }
  .reg-speculation { background: #EAE4D8; color: #2C2117; }
  .tl-count { font-size: 0.7rem; color: #999; margin-left: auto; }
  .tl-regions { font-size: 0.8rem; line-height: 1.6; color: #555; }
  .tl-region-line { margin: 0; }
  .tl-region-line strong { color: var(--dark-brown); }
  .tl-region-hidden { display: none; }
  .tl-expand-regions {
    background: none; border: none; font-size: 0.75rem; color: var(--terracotta);
    cursor: pointer; padding: 0.25rem 0; font-family: 'Pretendard', sans-serif; font-weight: 600;
  }
  .tl-notices {
    margin-top: 0.5rem; padding-top: 0.4rem; border-top: 1px solid #eae4d8;
    display: flex; flex-wrap: wrap; gap: 0.4rem; align-items: center;
    font-size: 0.7rem;
  }
  .tl-notice-link {
    color: var(--terracotta); font-weight: 600;
    display: inline-flex; align-items: center; gap: 0.25rem;
  }
  .tl-notice-link:hover { text-decoration: underline; }
  .tl-notice-text { color: #999; }
  .btn-more {
    display: block;
    width: 100%;
    padding: 0.7rem;
    background: #fff;
    border: 1.5px solid #eae4d8;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--dark-brown);
    cursor: pointer;
    font-family: 'Pretendard', sans-serif;
    transition: background 0.15s;
  }
  .btn-more:hover { background: #faf7f1; }

  /* ── 지역별 조회 ── */
  .region-search-wrap { margin-bottom: 1rem; }
  .region-search {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 0.9rem;
    font-family: 'Pretendard', sans-serif;
    border: 1.5px solid #ddd6c9;
    border-radius: 8px;
    background: #fff;
    color: var(--dark-brown);
    outline: none;
    transition: border-color 0.15s;
  }
  .region-search:focus { border-color: var(--terracotta); }
  .region-initial, .region-empty {
    text-align: center; color: #999; padding: 1.5rem 0; font-size: 0.85rem;
  }

  /* ── 공고 목록 ── */
  .notice-list { display: flex; flex-direction: column; gap: 0.25rem; }
  .notice-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    background: #fff;
    border: 1px solid #eae4d8;
    border-radius: 6px;
    padding: 0.45rem 0.75rem;
    font-size: 0.78rem;
  }
  .notice-date { font-size: 0.73rem; color: #777; white-space: nowrap; }
  .notice-reg {
    font-size: 0.6rem; font-weight: 700;
    padding: 0.08rem 0.35rem; border-radius: 3px;
    white-space: nowrap;
  }
  .notice-kind {
    font-size: 0.6rem; font-weight: 700;
    padding: 0.08rem 0.35rem; border-radius: 3px;
  }
  .nk-des { background: #F1E3E3; color: #7B3B3B; }
  .nk-lift { background: #F1F5F9; color: #64748B; }
  .nk-fix { background: #FFF7ED; color: #92400E; }
  .nk-both { background: #F0FDF4; color: #166534; }
  .notice-link { font-weight: 600; color: var(--terracotta); white-space: nowrap; }
  .notice-link:hover { text-decoration: underline; }
  .notice-unavailable { color: #999; white-space: nowrap; }
  .notice-ext {
    font-size: 0.55rem; font-weight: 700;
    padding: 0.05rem 0.3rem; border-radius: 3px;
    text-transform: uppercase;
  }
  .ext-pdf { background: #FEE2E2; color: #991B1B; }
  .ext-hwp { background: #DBEAFE; color: #1E40AF; }
  .notice-hidden { display: none; }

  /* ── 고지문구 ── */
  .legal-box {
    background: #faf7f1;
    border: 1px solid #eae4d8;
    border-radius: 10px;
    padding: 1.5rem;
    margin-bottom: 2rem;
    font-size: 0.75rem;
    color: #777;
    line-height: 1.7;
  }
  .legal-basis { font-weight: 700; color: var(--dark-brown); margin-bottom: 0.25rem; }
  .legal-source { margin-bottom: 0.75rem; }
  .legal-notes { margin: 0 0 0.75rem 1.25rem; }
  .legal-notes li { margin-bottom: 0.3rem; }
  .legal-warn {
    font-weight: 700;
    color: #7B3B3B;
    padding: 0.5rem 0.75rem;
    background: #F1E3E3;
    border-radius: 6px;
    font-size: 0.8rem;
  }

  /* ── Back ── */
  .back-wrap { margin-top: 2rem; margin-bottom: 3rem; text-align: center; }
  .back { font-size: 0.9rem; font-weight: 600; color: var(--terracotta); }

  /* ── Sidebar ── */
  .sidebar {
    width: 240px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: sticky;
    top: 80px;
    align-self: flex-start;
  }
  .sidebar-search {
    background: #fff;
    border-radius: 12px;
    border: 1px solid #eae4d8;
    padding: 1.25rem;
  }
  .sidebar-title {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--terracotta);
    margin-bottom: 0.75rem;
  }
  .search-input-wrap { display: flex; gap: 0; }
  .search-input {
    flex: 1; min-width: 0;
    border: 1.5px solid #ddd6c9; border-right: none;
    border-radius: 8px 0 0 8px;
    padding: 0.5rem 0.65rem; font-size: 0.8rem;
    font-family: 'Pretendard', sans-serif;
    background: #faf7f2; color: var(--dark-brown); outline: none;
  }
  .search-input:focus { border-color: var(--terracotta); }
  .search-btn {
    background: var(--dark-brown); border: none;
    border-radius: 0 8px 8px 0;
    padding: 0 0.6rem; color: var(--cream);
    cursor: pointer; display: flex; align-items: center;
  }
  .sidebar-cta {
    background: var(--dark-brown);
    border-radius: 12px;
    padding: 1.5rem 1.25rem;
    text-align: center;
  }
  .cta-label {
    font-family: 'SUIT Variable', 'Pretendard', sans-serif;
    font-size: 0.95rem; font-weight: 700;
    color: var(--cream); margin-bottom: 0.75rem;
  }
  .cta-btn {
    display: inline-block;
    background: var(--terracotta); color: #fff;
    font-weight: 700; font-size: 0.85rem;
    padding: 0.55rem 1.25rem; border-radius: 8px;
    transition: opacity 0.2s;
  }
  .cta-btn:hover { opacity: 0.85; }

  /* ── Mobile ── */
  @media (max-width: 1024px) {
    .layout { flex-direction: column; }
    .sidebar {
      width: 100%; position: static;
      flex-direction: row; flex-wrap: wrap;
    }
    .sidebar-search, .sidebar-cta { flex: 1; min-width: 240px; }
  }
  @media (max-width: 640px) {
    .sidebar { flex-direction: column; }
    .sidebar-search, .sidebar-cta { min-width: auto; }
    .tl-header { gap: 0.35rem; }
  }
</style>

<style is:global>
  /* 지역별 조회 결과 (JS로 생성) */
  .rr-section { margin-bottom: 1.25rem; }
  .rr-section-title {
    font-size: 0.85rem; font-weight: 700; color: var(--dark-brown);
    margin-bottom: 0.5rem; padding-bottom: 0.35rem;
    border-bottom: 1.5px solid #eae4d8;
    padding-left: 0.6rem; border-left: 3px solid transparent;
  }
  .rr-st-adjustment { border-left-color: #7B3B3B; color: #7B3B3B; }
  .rr-st-overheated { border-left-color: #D4622B; color: #D4622B; }
  .rr-st-speculation { border-left-color: #2C2117; color: #2C2117; }
  .rr-row {
    background: #fff; border: 1px solid #eae4d8; border-radius: 8px;
    padding: 0.75rem 1rem; margin-bottom: 0.4rem;
    font-size: 0.8rem; line-height: 1.6;
    word-break: keep-all; overflow-wrap: break-word;
  }
  .rr-pills { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 1rem; }
  .rr-pill {
    font-size: 0.8rem; font-weight: 600; padding: 0.3rem 0.75rem;
    border-radius: 20px; cursor: pointer; border: 1.5px solid #7B3B3B;
    color: #7B3B3B; background: transparent;
    font-family: 'Pretendard', sans-serif; transition: all 0.15s;
  }
  .rr-pill:hover { background: #F1E3E3; }
  .rr-pill-active { background: #7B3B3B; color: #fff; border-color: #7B3B3B; }
  .rr-pill-active:hover { background: #5a2c2c; }
  .rr-pill-selected { box-shadow: 0 0 0 2px #7B3B3B; }
  .rr-pill-active.rr-pill-selected { background: #5a2c2c; }
  .rr-detail { margin-top: 0.5rem; }
  .rr-detail-title {
    font-size: 1rem; font-weight: 700; color: var(--dark-brown);
    margin-bottom: 0.75rem; padding-bottom: 0.4rem;
    border-bottom: 2px solid var(--dark-brown);
  }
  .rr-period { font-weight: 600; color: var(--dark-brown); font-size: 0.78rem; }
  .rr-scope { font-size: 0.73rem; color: #999; margin-top: 0.1rem; word-break: keep-all; overflow-wrap: break-word; }
  .rr-badges { display: inline-flex; gap: 0.3rem; margin-left: 0.5rem; vertical-align: middle; }
  .rr-badge {
    font-size: 0.6rem; font-weight: 700; padding: 0.05rem 0.35rem;
    border-radius: 3px; vertical-align: middle;
  }
  .rr-active { background: #7B3B3B; color: #fff; }
  .rr-redesignation { background: transparent; border: 1px solid #7B3B3B; color: #7B3B3B; }
  .rr-verify { background: #FFF7ED; color: #92400E; }
  .rr-target { background: #F1F5F9; color: #64748B; }
  .rr-notice { font-size: 0.7rem; color: #999; margin-top: 0.2rem; }
  .rr-notice a { color: var(--terracotta); }
  .rr-note { font-size: 0.7rem; color: #999; margin-top: 0.15rem; }
  .rr-old-toggle {
    display: block; width: 100%;
    background: #faf7f1; border: 1px dashed #ddd6c9;
    border-radius: 8px; padding: 0.6rem; margin-bottom: 0.5rem;
    font-size: 0.8rem; font-weight: 600; color: #777;
    cursor: pointer; font-family: 'Pretendard', sans-serif; text-align: center;
  }
  .rr-old-toggle:hover { background: #f0ebe3; }
  .rr-old-hidden { display: none; }
</style>

<script define:vars={{ clientPeriods, clientNoticeMap, REGULATION_TYPE_LABEL }}>
document.addEventListener('DOMContentLoaded', () => {
  // ── 토글 헬퍼 ──
  function setupToggle(btnId, itemSelector, hiddenClass, limit, sectionId) {
    const btn = document.getElementById(btnId);
    if (!btn) return;
    const allItems = document.querySelectorAll(itemSelector);
    const extra = allItems.length - limit;
    if (extra <= 0) return;
    let expanded = false;

    const collapseLabel = btnId === 'btn-timeline-more'
      ? `전체 연혁 보기 (${extra}건 더)`
      : `공고 전체 보기 (${extra}건 더)`;
    const expandLabel = '접기';

    btn.addEventListener('click', () => {
      expanded = !expanded;
      allItems.forEach((el, i) => {
        if (i >= limit) {
          if (expanded) el.classList.remove(hiddenClass);
          else el.classList.add(hiddenClass);
        }
      });
      btn.textContent = expanded ? expandLabel : collapseLabel;
      if (!expanded) {
        document.getElementById(sectionId).scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  }
  setupToggle('btn-timeline-more', '#timeline .tl-card', 'tl-hidden', 4, 'section-timeline');
  setupToggle('btn-notices-more', '.notice-list .notice-row', 'notice-hidden', 4, 'section-notices');

  // 카드 클릭 → 숨겨진 지역 펼침
  document.querySelectorAll('.tl-card').forEach(card => {
    card.addEventListener('click', (e) => {
      if (e.target.closest('.tl-expand-regions')) return;
      card.querySelectorAll('.tl-region-hidden').forEach(el => el.classList.remove('tl-region-hidden'));
      const btn = card.querySelector('.tl-expand-regions');
      if (btn) btn.style.display = 'none';
    });
  });
  document.querySelectorAll('.tl-expand-regions').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const card = btn.closest('.tl-card');
      card.querySelectorAll('.tl-region-hidden').forEach(el => el.classList.remove('tl-region-hidden'));
      btn.style.display = 'none';
    });
  });

  // ── 지역별 조회 ──
  const typeOrder = ['adjustment', 'overheated', 'speculation'];
  const SIDO_ALIAS = {
    '서울':'서울특별시','부산':'부산광역시','대구':'대구광역시','인천':'인천광역시',
    '광주':'광주광역시','대전':'대전광역시','울산':'울산광역시','세종':'세종특별자치시',
    '경기':'경기도','강원':'강원도','충북':'충청북도','충남':'충청남도',
    '전북':'전라북도','전남':'전라남도','경북':'경상북도','경남':'경상남도',
    '제주':'제주특별자치도',
  };
  const input = document.getElementById('region-search');
  if (!input) return;
  const resultsEl = document.getElementById('region-results');
  const initialEl = document.getElementById('region-initial');
  const emptyEl = document.getElementById('region-empty');

  // 구(舊) 투기지역 토글 — 이벤트 위임
  resultsEl.addEventListener('click', (e) => {
    const toggleBtn = e.target.closest('.rr-old-toggle');
    if (!toggleBtn) return;
    const rows = toggleBtn.nextElementSibling;
    if (rows.classList.contains('rr-old-hidden')) {
      rows.classList.remove('rr-old-hidden');
      toggleBtn.textContent = '구(舊) 투기지역 이력 접기';
    } else {
      rows.classList.add('rr-old-hidden');
      toggleBtn.textContent = `구(舊) 투기지역 이력 보기 (2003~2012 · ${rows.querySelectorAll('.rr-row').length}건)`;
    }
  });

  let selectedKey = null;

  function search(query) {
    const q = query.trim();
    selectedKey = null;
    if (!q) {
      resultsEl.innerHTML = '';
      emptyEl.style.display = 'none';
      initialEl.style.display = '';
      return;
    }
    initialEl.style.display = 'none';

    // 축약형 확장
    const expanded = SIDO_ALIAS[q];
    const queries = expanded ? [q, expanded] : [q];

    const matches = clientPeriods
      .filter(p => queries.some(qq => p.sido.includes(qq) || p.region.includes(qq) || (p.scope || '').includes(qq)));

    if (matches.length === 0) {
      resultsEl.innerHTML = '';
      emptyEl.style.display = '';
      return;
    }
    emptyEl.style.display = 'none';

    // sido+region 고유값 추출
    const regionMap = new Map();
    for (const m of matches) {
      const key = m.sido + '|' + m.region;
      if (!regionMap.has(key)) {
        regionMap.set(key, { sido: m.sido, region: m.region, active: false, records: [] });
      }
      const entry = regionMap.get(key);
      entry.records.push(m);
      if (!m.lifted) entry.active = true;
    }
    const regions = [...regionMap.values()];

    // 정렬: 현재 지정 중 먼저 → 가나다순
    regions.sort((a, b) => {
      if (a.active !== b.active) return a.active ? -1 : 1;
      return (a.sido + a.region).localeCompare(b.sido + b.region);
    });

    // 시도가 여러 개 섞여있는지
    const sidos = new Set(regions.map(r => r.sido));
    const multiSido = sidos.size > 1;

    // 1개뿐이면 바로 상세 펼침
    if (regions.length === 1) {
      const r = regions[0];
      const key = r.sido + '|' + r.region;
      selectedKey = key;
      resultsEl.innerHTML = renderDetail(r.sido + ' ' + r.region, r.records);
      return;
    }

    // 알약 목록 렌더링
    let html = '<div class="rr-pills">';
    for (const r of regions) {
      const key = r.sido + '|' + r.region;
      const label = multiSido ? (r.sido.replace(/특별시|광역시|특별자치시|특별자치도/, '') + ' ' + r.region) : r.region;
      const cls = r.active ? 'rr-pill rr-pill-active' : 'rr-pill';
      html += `<button class="${cls}" data-key="${key}">${label}</button>`;
    }
    html += '</div><div id="rr-detail-area"></div>';
    resultsEl.innerHTML = html;

    // 알약 클릭 이벤트
    resultsEl.querySelectorAll('.rr-pill').forEach(pill => {
      pill.addEventListener('click', () => {
        const key = pill.dataset.key;
        const detailArea = document.getElementById('rr-detail-area');

        // 같은 알약 재클릭 → 닫기
        if (selectedKey === key) {
          selectedKey = null;
          detailArea.innerHTML = '';
          resultsEl.querySelectorAll('.rr-pill').forEach(p => p.classList.remove('rr-pill-selected'));
          return;
        }

        selectedKey = key;
        resultsEl.querySelectorAll('.rr-pill').forEach(p => p.classList.remove('rr-pill-selected'));
        pill.classList.add('rr-pill-selected');

        const entry = regionMap.get(key);
        detailArea.innerHTML = renderDetail(entry.sido + ' ' + entry.region, entry.records);
        });
    });
  }

  function renderDetail(title, records) {
    const sorted = records.sort((a, b) =>
      typeOrder.indexOf(a.type) - typeOrder.indexOf(b.type) ||
      (b.designated || b.lifted || '').localeCompare(a.designated || a.lifted || '')
    );

    // 규제종류별 그룹
    const groups = {};
    for (const m of sorted) {
      if (!groups[m.type]) groups[m.type] = [];
      groups[m.type].push(m);
    }

    let html = `<div class="rr-detail"><p class="rr-detail-title">${title}</p>`;
    for (const type of typeOrder) {
      if (!groups[type]) continue;
      const items = groups[type];
      const label = REGULATION_TYPE_LABEL[type];

      let mainItems = items;
      let oldItems = [];
      if (type === 'speculation') {
        mainItems = items.filter(p => p.designated >= '2013-01-01');
        oldItems = items.filter(p => p.designated < '2013-01-01');
      }

      html += `<div class="rr-section"><p class="rr-section-title rr-st-${type}">${label}</p>`;
      html += renderRows(mainItems);

      if (oldItems.length > 0) {
        html += `<button class="rr-old-toggle">구(舊) 투기지역 이력 보기 (2003~2012 · ${oldItems.length}건)</button>`;
        html += `<div class="rr-old-hidden rr-old-rows">`;
        html += renderRows(oldItems);
        html += `</div>`;
      }
      html += `</div>`;
    }
    html += '</div>';
    return html;
  }

  function renderRows(items) {
    return items.map(p => {
      const period = (p.designated ? fmtD(p.designated) : '지정일 미상') + ' ~ ' + (p.lifted ? fmtD(p.lifted) : '현재');
      let badges = '';
      if (!p.lifted) badges += '<span class="rr-badge rr-active">현재 지정 중</span>';
      if (p.redesignation) badges += '<span class="rr-badge rr-redesignation">재지정</span>';
      if (p.needsVerify) badges += '<span class="rr-badge rr-verify">원문 확인 필요</span>';
      if (p.target) badges += `<span class="rr-badge rr-target">${p.target}</span>`;

      let noticeHtml = '';
      if (p.designationNotice) noticeHtml += renderNoticeLink('지정', p.designationNotice);
      if (p.liftNotice) noticeHtml += renderNoticeLink('해제', p.liftNotice);

      return `<div class="rr-row">
        <span class="rr-period">${period}</span>
        ${badges ? `<span class="rr-badges">${badges}</span>` : ''}
        ${p.scope ? `<p class="rr-scope">${p.scope}</p>` : ''}
        ${noticeHtml ? `<p class="rr-notice">${noticeHtml}</p>` : ''}
        ${p.note ? `<p class="rr-note">${p.note}</p>` : ''}
      </div>`;
    }).join('');
  }


  function renderNoticeLink(label, noticeText) {
    const re = /제(\d+-\d+)호/g;
    let match;
    const links = [];
    while ((match = re.exec(noticeText)) !== null) {
      const num = match[1];
      for (const [id, info] of Object.entries(clientNoticeMap)) {
        if (id.includes(num) && info.file) {
          const ext = info.file.split('.').pop().toUpperCase();
          const dl = ext === 'HWP' ? ' download' : '';
          links.push(`<a href="${info.file}" target="_blank" rel="noopener"${dl}>${id}</a> <span class="rr-badge" style="font-size:0.55rem">${ext}</span>`);
          break;
        }
      }
    }
    if (links.length > 0) return `${label}: ${links.join(' ')} `;
    return `${label}: ${noticeText} `;
  }

  function fmtD(d) { return d.split('-').map((s, i) => i === 0 ? s : String(Number(s))).join('.'); }

  input.addEventListener('input', (e) => search(e.target.value));

  // URL 쿼리로 초기 검색
  const params = new URLSearchParams(window.location.search);
  const initQ = params.get('q');
  if (initQ) {
    input.value = initQ;
    search(initQ);
    document.getElementById('region-search-section').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
}); // DOMContentLoaded
</script>
