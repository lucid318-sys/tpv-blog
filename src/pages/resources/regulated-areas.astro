---
import Base from "../../layouts/Base.astro";
import { ADJUSTED_AREAS, SPECULATION_AREAS, REFERENCE_DATE } from "../../data/regulatedAreas";
import {
  regulationPeriods, officialNotices, toTimelineEvents,
  REGULATION_TYPE_LABEL, HISTORY_BASE_DATE, SPECULATION_BASE_DATE,
  LEGAL_NOTES,
  type RegulationEvent, type RegulationType,
} from "../../data/regulatedAreaHistory";

// ── 타임라인 그룹핑 (speculation 제외) ──
const events = toTimelineEvents(regulationPeriods.filter(p => p.type !== 'speculation'));
interface TimelineGroup {
  date: string;
  kind: '지정' | '해제';
  type: RegulationType;
  typeLabel: string;
  regions: { sido: string; region: string; scope?: string }[];
}
const groupMap = new Map<string, TimelineGroup>();
for (const ev of events) {
  const key = `${ev.date}|${ev.type}|${ev.kind}`;
  if (!groupMap.has(key)) {
    groupMap.set(key, {
      date: ev.date,
      kind: ev.kind,
      type: ev.type,
      typeLabel: REGULATION_TYPE_LABEL[ev.type],
      regions: [],
    });
  }
  groupMap.get(key)!.regions.push({ sido: ev.sido, region: ev.region, scope: ev.scope });
}
const timelineGroups = [...groupMap.values()];

// 시도별로 묶어 요약 텍스트 생성
function summarizeRegions(regions: { sido: string; region: string; scope?: string }[]): { sido: string; names: string }[] {
  const byDo = new Map<string, string[]>();
  for (const r of regions) {
    if (!byDo.has(r.sido)) byDo.set(r.sido, []);
    byDo.get(r.sido)!.push(r.region + (r.scope ? `(${r.scope})` : ''));
  }
  return [...byDo.entries()].map(([sido, names]) => ({ sido, names: names.join(', ') }));
}

// 공고 날짜 내림차순
const sortedNotices = [...officialNotices].sort((a, b) => b.date.localeCompare(a.date));

// 기준일 포맷
function fmtDate(d: string) { return d.replace(/-/g, '.'); }

// 클라이언트에 전달할 데이터 (인라인 JSON)
const clientPeriods = regulationPeriods.map(p => ({
  type: p.type, sido: p.sido, region: p.region,
  scope: p.scope, target: p.target,
  designated: p.designated, lifted: p.lifted,
  redesignation: p.redesignation, note: p.note,
  designationNotice: p.designationNotice, liftNotice: p.liftNotice,
  needsVerify: p.needsVerify,
}));
const clientNoticeMap: Record<string, { file?: string }> = {};
for (const n of officialNotices) {
  // 공고 ID에서 짧은 키 추출 (예: "제2025-1223호")
  clientNoticeMap[n.id] = { file: n.file };
}
---
<Base title="규제지역 지정현황">
  <main class="layout">
    <div class="content">
      <div class="header">
        <h1 class="page-title">규제지역 지정현황</h1>
        <span class="date-badge">{REFERENCE_DATE} 기준</span>
      </div>

      {/* ① 현재 지정현황 표 */}
      <section class="section">
        <h2 class="section-title">조정대상지역</h2>
        <div class="table-wrap">
          <table>
            <thead><tr><th>지역</th><th>구 · 시</th></tr></thead>
            <tbody>
              {ADJUSTED_AREAS.map((g) => (
                <tr>
                  <td class="region">{g.region}</td>
                  <td>{g.areas.join(", ")}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <section class="section">
        <h2 class="section-title">투기과열지구</h2>
        <div class="table-wrap">
          <table>
            <thead><tr><th>지역</th><th>구 · 시</th></tr></thead>
            <tbody>
              {SPECULATION_AREAS.map((g) => (
                <tr>
                  <td class="region">{g.region}</td>
                  <td>{g.areas.join(", ")}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      {/* ② 지역별 조회 */}
      <section class="section">
        <h2 class="section-title">지역별 조회</h2>
        <div class="region-search-wrap">
          <input type="text" id="region-search" class="region-search" placeholder="지역명 입력 (예: 강남, 화성, 세종)" />
        </div>
        <div id="region-results"></div>
        <p id="region-initial" class="region-initial">지역명을 입력하면 규제지역 지정·해제 이력을 조회합니다.</p>
        <p id="region-empty" class="region-empty" style="display:none;">검색 결과가 없습니다.</p>
      </section>

      {/* ③ 지정·해제 연혁 타임라인 */}
      <section class="section" id="section-timeline">
        <h2 class="section-title">지정 · 해제 연혁</h2>
        <div id="timeline">
          {timelineGroups.map((g, i) => {
            const summary = summarizeRegions(g.regions);
            const isDesignation = g.kind === '지정';
            return (
              <div
                class={`tl-card ${isDesignation ? 'tl-designation' : 'tl-lift'} ${i >= 4 ? 'tl-hidden' : ''}`}
                data-tl-idx={i}
              >
                <div class="tl-header">
                  <span class="tl-date">{fmtDate(g.date)}</span>
                  <span class={`tl-kind ${isDesignation ? 'kind-designation' : 'kind-lift'}`}>{g.kind}</span>
                  <span class="tl-type">{g.typeLabel}</span>
                  <span class="tl-count">{g.regions.length}곳</span>
                </div>
                <div class="tl-regions">
                  {summary.map((s, si) => (
                    <p class={`tl-region-line ${si >= 3 ? 'tl-region-hidden' : ''}`}>
                      <strong>{s.sido}</strong> {s.names}
                    </p>
                  ))}
                  {summary.length > 3 && (
                    <button class="tl-expand-regions" data-action="expand-regions">+ {summary.length - 3}개 시도 더보기</button>
                  )}
                </div>
              </div>
            );
          })}
        </div>
        {timelineGroups.length > 4 && (
          <button class="btn-more" id="btn-timeline-more" data-total={timelineGroups.length} data-limit="4">
            전체 연혁 보기 ({timelineGroups.length - 4}건 더)
          </button>
        )}
      </section>

      {/* ④ 원본 공고 다운로드 */}
      <section class="section" id="section-notices">
        <h2 class="section-title">원본 공고 다운로드</h2>
        <div class="notice-list">
          {sortedNotices.map((n, i) => {
            const ext = n.file ? n.file.split('.').pop()?.toUpperCase() : null;
            return (
              <div class={`notice-item ${i >= 4 ? 'notice-hidden' : ''}`}>
                <div class="notice-meta">
                  <span class={`notice-kind nk-${n.kind === '지정' ? 'des' : n.kind === '해제' ? 'lift' : n.kind === '정정' ? 'fix' : 'both'}`}>{n.kind}</span>
                  <span class="notice-date">{fmtDate(n.date)}</span>
                  {ext && <span class={`notice-ext ext-${ext.toLowerCase()}`}>{ext}</span>}
                </div>
                <p class="notice-id">
                  {n.file ? (
                    <a href={n.file} target="_blank" rel="noopener" download>{n.id}</a>
                  ) : (
                    <span class="notice-unavailable">{n.id} <small>(미확보)</small></span>
                  )}
                </p>
                <p class="notice-summary">{n.summary}</p>
              </div>
            );
          })}
        </div>
        {sortedNotices.length > 4 && (
          <button class="btn-more" id="btn-notices-more" data-total={sortedNotices.length} data-limit="4">
            공고 전체 보기 ({sortedNotices.length - 4}건 더)
          </button>
        )}
      </section>

      {/* ⑤ 고지문구 */}
      <div class="legal-box">
        <p class="legal-basis">
          조정대상지역 · 투기과열지구: {fmtDate(HISTORY_BASE_DATE)} 기준 / 투기지역: {fmtDate(SPECULATION_BASE_DATE)} 기준
        </p>
        <p class="legal-source">출처: 국토교통부 공고 · etaxkorea 조세자료 정리</p>
        <ul class="legal-notes">
          {LEGAL_NOTES.map((note) => (
            <li>{note}</li>
          ))}
        </ul>
        <p class="legal-warn">본 자료는 참고용이며, 세무 판단 시 반드시 원문 공고를 확인하시기 바랍니다.</p>
      </div>

      <div class="back-wrap">
        <a href="/resources/" class="back">&larr; 서식 · 자료로 돌아가기</a>
      </div>
    </div>

    <aside class="sidebar">
      <form class="sidebar-search" action="/search/" method="get">
        <p class="sidebar-title">키워드로 찾기</p>
        <div class="search-input-wrap">
          <input type="text" name="q" placeholder="검색어 입력" class="search-input" />
          <button type="submit" class="search-btn" aria-label="검색">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </button>
        </div>
      </form>

      <div class="sidebar-cta">
        <p class="cta-label">상담이 필요하세요?</p>
        <a href="https://pf.kakao.com/_dcihX/chat" target="_blank" rel="noopener" class="cta-btn">
          카카오톡 상담
        </a>
      </div>
    </aside>
  </main>
</Base>

<style>
  /* ── Layout ── */
  .layout {
    max-width: 1080px;
    margin: 0 auto;
    padding: 2rem 1.5rem 0;
    display: flex;
    gap: 2rem;
    align-items: flex-start;
  }
  .content {
    flex: 1;
    min-width: 0;
  }
  .header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  .page-title {
    font-family: 'SUIT Variable', 'Pretendard', sans-serif;
    font-size: 1.6rem;
    font-weight: 700;
  }
  .date-badge {
    font-size: 0.75rem;
    font-weight: 700;
    background: var(--terracotta);
    color: #fff;
    padding: 0.25rem 0.65rem;
    border-radius: 20px;
  }

  .section { margin-bottom: 2.5rem; }
  .section-title {
    font-family: 'SUIT Variable', 'Pretendard', sans-serif;
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--dark-brown);
  }

  /* ── Table (현재 지정현황) ── */
  .table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-radius: 8px;
    border: 1px solid #e8e2d6;
    max-width: 100%;
  }
  table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
  th {
    background: var(--dark-brown);
    color: var(--cream);
    font-weight: 700;
    padding: 0.65rem 1rem;
    text-align: left;
    white-space: nowrap;
  }
  td { padding: 0.7rem 1rem; border-top: 1px solid #e8e2d6; line-height: 1.7; }
  tr:nth-child(even) td { background: #faf7f1; }
  .region { white-space: nowrap; font-weight: 700; }

  /* ── 타임라인 ── */
  .tl-card {
    background: #fff;
    border: 1px solid #eae4d8;
    border-radius: 10px;
    padding: 1rem 1.25rem;
    margin-bottom: 0.6rem;
    cursor: pointer;
    transition: box-shadow 0.15s;
  }
  .tl-card:hover { box-shadow: 0 2px 12px rgba(44,33,23,0.08); }
  .tl-designation { border-left: 4px solid #7B3B3B; }
  .tl-lift { border-left: 4px solid #64748B; }
  .tl-hidden { display: none; }
  .tl-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }
  .tl-date { font-size: 0.8rem; font-weight: 700; color: var(--dark-brown); }
  .tl-kind {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
  }
  .kind-designation { background: #F1E3E3; color: #7B3B3B; }
  .kind-lift { background: #F1F5F9; color: #64748B; }
  .tl-type { font-size: 0.75rem; color: #777; }
  .tl-count { font-size: 0.7rem; color: #999; margin-left: auto; }
  .tl-regions { font-size: 0.8rem; line-height: 1.6; color: #555; }
  .tl-region-line { margin: 0; }
  .tl-region-line strong { color: var(--dark-brown); }
  .tl-region-hidden { display: none; }
  .tl-expand-regions {
    background: none; border: none; font-size: 0.75rem; color: var(--terracotta);
    cursor: pointer; padding: 0.25rem 0; font-family: 'Pretendard', sans-serif; font-weight: 600;
  }
  .btn-more {
    display: block;
    width: 100%;
    padding: 0.7rem;
    background: #fff;
    border: 1.5px solid #eae4d8;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--dark-brown);
    cursor: pointer;
    font-family: 'Pretendard', sans-serif;
    transition: background 0.15s;
  }
  .btn-more:hover { background: #faf7f1; }

  /* ── 지역별 조회 ── */
  .region-search-wrap { margin-bottom: 1rem; }
  .region-search {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 0.9rem;
    font-family: 'Pretendard', sans-serif;
    border: 1.5px solid #ddd6c9;
    border-radius: 8px;
    background: #fff;
    color: var(--dark-brown);
    outline: none;
    transition: border-color 0.15s;
