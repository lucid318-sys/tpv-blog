  .region-search:focus { border-color: var(--terracotta); }
  .region-initial, .region-empty {
    text-align: center; color: #999; padding: 1.5rem 0; font-size: 0.85rem;
  }

  /* ── 공고 목록 ── */
  .notice-list { display: flex; flex-direction: column; gap: 0.5rem; }
  .notice-item {
    background: #fff;
    border: 1px solid #eae4d8;
    border-radius: 10px;
    padding: 1rem 1.25rem;
  }
  .notice-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.35rem;
  }
  .notice-kind {
    font-size: 0.65rem;
    font-weight: 700;
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
  }
  .nk-des { background: #F1E3E3; color: #7B3B3B; }
  .nk-lift { background: #F1F5F9; color: #64748B; }
  .nk-fix { background: #FFF7ED; color: #92400E; }
  .nk-both { background: #F0FDF4; color: #166534; }
  .notice-date { font-size: 0.75rem; color: #777; }
  .notice-ext {
    font-size: 0.6rem;
    font-weight: 700;
    padding: 0.05rem 0.35rem;
    border-radius: 3px;
    text-transform: uppercase;
  }
  .ext-pdf { background: #FEE2E2; color: #991B1B; }
  .ext-hwp { background: #DBEAFE; color: #1E40AF; }
  .notice-id { font-size: 0.8rem; font-weight: 600; margin-bottom: 0.25rem; }
  .notice-id a { color: var(--terracotta); }
  .notice-id a:hover { text-decoration: underline; }
  .notice-unavailable { color: #999; }
  .notice-summary { font-size: 0.8rem; color: #555; line-height: 1.6; }
  .notice-hidden { display: none; }

  /* ── 고지문구 ── */
  .legal-box {
    background: #faf7f1;
    border: 1px solid #eae4d8;
    border-radius: 10px;
    padding: 1.5rem;
    margin-bottom: 2rem;
    font-size: 0.75rem;
    color: #777;
    line-height: 1.7;
  }
  .legal-basis { font-weight: 700; color: var(--dark-brown); margin-bottom: 0.25rem; }
  .legal-source { margin-bottom: 0.75rem; }
  .legal-notes { margin: 0 0 0.75rem 1.25rem; }
  .legal-notes li { margin-bottom: 0.3rem; }
  .legal-warn {
    font-weight: 700;
    color: #7B3B3B;
    padding: 0.5rem 0.75rem;
    background: #F1E3E3;
    border-radius: 6px;
    font-size: 0.8rem;
  }

  /* ── Back ── */
  .back-wrap { margin-top: 2rem; margin-bottom: 3rem; text-align: center; }
  .back { font-size: 0.9rem; font-weight: 600; color: var(--terracotta); }

  /* ── Sidebar ── */
  .sidebar {
    width: 240px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: sticky;
    top: 80px;
    align-self: flex-start;
  }
  .sidebar-search {
    background: #fff;
    border-radius: 12px;
    border: 1px solid #eae4d8;
    padding: 1.25rem;
  }
  .sidebar-title {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--terracotta);
    margin-bottom: 0.75rem;
  }
  .search-input-wrap { display: flex; gap: 0; }
  .search-input {
    flex: 1; min-width: 0;
    border: 1.5px solid #ddd6c9; border-right: none;
    border-radius: 8px 0 0 8px;
    padding: 0.5rem 0.65rem; font-size: 0.8rem;
    font-family: 'Pretendard', sans-serif;
    background: #faf7f2; color: var(--dark-brown); outline: none;
  }
  .search-input:focus { border-color: var(--terracotta); }
  .search-btn {
    background: var(--dark-brown); border: none;
    border-radius: 0 8px 8px 0;
    padding: 0 0.6rem; color: var(--cream);
    cursor: pointer; display: flex; align-items: center;
  }
  .sidebar-cta {
    background: var(--dark-brown);
    border-radius: 12px;
    padding: 1.5rem 1.25rem;
    text-align: center;
  }
  .cta-label {
    font-family: 'SUIT Variable', 'Pretendard', sans-serif;
    font-size: 0.95rem; font-weight: 700;
    color: var(--cream); margin-bottom: 0.75rem;
  }
  .cta-btn {
    display: inline-block;
    background: var(--terracotta); color: #fff;
    font-weight: 700; font-size: 0.85rem;
    padding: 0.55rem 1.25rem; border-radius: 8px;
    transition: opacity 0.2s;
  }
  .cta-btn:hover { opacity: 0.85; }

  /* ── Mobile ── */
  @media (max-width: 1024px) {
    .layout { flex-direction: column; }
    .sidebar {
      width: 100%; position: static;
      flex-direction: row; flex-wrap: wrap;
    }
    .sidebar-search, .sidebar-cta { flex: 1; min-width: 240px; }
  }
  @media (max-width: 640px) {
    .sidebar { flex-direction: column; }
    .sidebar-search, .sidebar-cta { min-width: auto; }
    .tl-header { gap: 0.35rem; }
  }
</style>

<style is:global>
  /* 지역별 조회 결과 (JS로 생성) */
  .rr-section { margin-bottom: 1.25rem; }
  .rr-section-title {
    font-size: 0.85rem; font-weight: 700; color: var(--dark-brown);
    margin-bottom: 0.5rem; padding-bottom: 0.35rem;
    border-bottom: 1.5px solid #eae4d8;
  }
  .rr-row {
    background: #fff; border: 1px solid #eae4d8; border-radius: 8px;
    padding: 0.75rem 1rem; margin-bottom: 0.4rem;
    font-size: 0.8rem; line-height: 1.6;
  }
  .rr-period { font-weight: 600; color: var(--dark-brown); }
  .rr-scope { font-size: 0.75rem; color: #999; margin-left: 0.5rem; }
  .rr-badges { display: inline-flex; gap: 0.3rem; margin-left: 0.5rem; vertical-align: middle; }
  .rr-badge {
    font-size: 0.6rem; font-weight: 700; padding: 0.05rem 0.35rem;
    border-radius: 3px; vertical-align: middle;
  }
  .rr-active { background: #7B3B3B; color: #fff; }
  .rr-redesignation { background: transparent; border: 1px solid #7B3B3B; color: #7B3B3B; }
  .rr-verify { background: #FFF7ED; color: #92400E; }
  .rr-target { background: #F1F5F9; color: #64748B; }
  .rr-notice { font-size: 0.7rem; color: #999; margin-top: 0.2rem; }
  .rr-notice a { color: var(--terracotta); }
  .rr-note { font-size: 0.7rem; color: #999; margin-top: 0.15rem; }
  .rr-old-toggle {
    display: block; width: 100%;
    background: #faf7f1; border: 1px dashed #ddd6c9;
    border-radius: 8px; padding: 0.6rem; margin-bottom: 0.5rem;
    font-size: 0.8rem; font-weight: 600; color: #777;
    cursor: pointer; font-family: 'Pretendard', sans-serif; text-align: center;
  }
  .rr-old-toggle:hover { background: #f0ebe3; }
  .rr-old-hidden { display: none; }
</style>

<script define:vars={{ clientPeriods, clientNoticeMap, REGULATION_TYPE_LABEL }}>
  // ── 토글 헬퍼 ──
  function setupToggle(btnId, hiddenClass, sectionId) {
    const btn = document.getElementById(btnId);
    if (!btn) return;
    const limit = parseInt(btn.dataset.limit);
    const total = parseInt(btn.dataset.total);
    const extra = total - limit;
    let expanded = false;

    const collapseLabel = btnId === 'btn-timeline-more'
      ? `전체 연혁 보기 (${extra}건 더)`
      : `공고 전체 보기 (${extra}건 더)`;
    const expandLabel = '접기';

    btn.addEventListener('click', () => {
      expanded = !expanded;
      document.querySelectorAll('.' + hiddenClass).forEach(el => {
        if (expanded) el.classList.remove(hiddenClass);
        else el.classList.add(hiddenClass);
      });
      btn.textContent = expanded ? expandLabel : collapseLabel;
      if (!expanded) {
        document.getElementById(sectionId).scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  }
  setupToggle('btn-timeline-more', 'tl-hidden', 'section-timeline');
  setupToggle('btn-notices-more', 'notice-hidden', 'section-notices');

  // 카드 클릭 → 숨겨진 지역 펼침
  document.querySelectorAll('.tl-card').forEach(card => {
    card.addEventListener('click', (e) => {
      if (e.target.closest('.tl-expand-regions')) return;
      card.querySelectorAll('.tl-region-hidden').forEach(el => el.classList.remove('tl-region-hidden'));
      const btn = card.querySelector('.tl-expand-regions');
      if (btn) btn.style.display = 'none';
    });
  });
  document.querySelectorAll('.tl-expand-regions').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const card = btn.closest('.tl-card');
      card.querySelectorAll('.tl-region-hidden').forEach(el => el.classList.remove('tl-region-hidden'));
      btn.style.display = 'none';
    });
  });

  // ── 지역별 조회 ──
  const typeOrder = ['adjustment', 'overheated', 'speculation'];
  const input = document.getElementById('region-search');
  const resultsEl = document.getElementById('region-results');
  const initialEl = document.getElementById('region-initial');
  const emptyEl = document.getElementById('region-empty');

  function search(query) {
    const q = query.trim();
    if (!q) {
      resultsEl.innerHTML = '';
      emptyEl.style.display = 'none';
      initialEl.style.display = '';
      return;
    }
    initialEl.style.display = 'none';

    const matches = clientPeriods
      .filter(p => p.sido.includes(q) || p.region.includes(q) || (p.scope || '').includes(q))
      .sort((a, b) => typeOrder.indexOf(a.type) - typeOrder.indexOf(b.type) || a.designated.localeCompare(b.designated));

    if (matches.length === 0) {
      resultsEl.innerHTML = '';
      emptyEl.style.display = '';
      return;
    }
    emptyEl.style.display = 'none';

    // 규제종류별 그룹
    const groups = {};
    for (const m of matches) {
      if (!groups[m.type]) groups[m.type] = [];
      groups[m.type].push(m);
    }

    let html = '';
    for (const type of typeOrder) {
      if (!groups[type]) continue;
      const items = groups[type];
      const label = REGULATION_TYPE_LABEL[type];

      // 구(舊) 투기지역 분리
      let mainItems = items;
      let oldItems = [];
      if (type === 'speculation') {
        mainItems = items.filter(p => p.designated >= '2013-01-01');
        oldItems = items.filter(p => p.designated < '2013-01-01');
      }

      html += `<div class="rr-section"><p class="rr-section-title">${label}</p>`;
      html += renderRows(mainItems);

      if (oldItems.length > 0) {
        html += `<button class="rr-old-toggle" data-toggle="old-speculation">구(舊) 투기지역 이력 보기 (2003~2012 · ${oldItems.length}건)</button>`;
        html += `<div class="rr-old-hidden" id="old-speculation-rows">`;
        html += renderRows(oldItems);
        html += `</div>`;
      }

      html += `</div>`;
    }

    resultsEl.innerHTML = html;

    // 구(舊) 투기지역 토글
    const toggleBtn = resultsEl.querySelector('.rr-old-toggle');
    if (toggleBtn) {
      toggleBtn.addEventListener('click', () => {
        const rows = document.getElementById('old-speculation-rows');
        if (rows.classList.contains('rr-old-hidden')) {
          rows.classList.remove('rr-old-hidden');
          toggleBtn.textContent = '구(舊) 투기지역 이력 접기';
        } else {
          rows.classList.add('rr-old-hidden');
          toggleBtn.textContent = `구(舊) 투기지역 이력 보기 (2003~2012 · ${rows.querySelectorAll('.rr-row').length}건)`;
        }
      });
    }
  }

  function renderRows(items) {
    return items.map(p => {
      const period = fmtD(p.designated) + ' ~ ' + (p.lifted ? fmtD(p.lifted) : '현재');
      let badges = '';
      if (!p.lifted) badges += '<span class="rr-badge rr-active">현재 지정 중</span>';
      if (p.redesignation) badges += '<span class="rr-badge rr-redesignation">재지정</span>';
      if (p.needsVerify) badges += '<span class="rr-badge rr-verify">원문 확인 필요</span>';
      if (p.target) badges += `<span class="rr-badge rr-target">${p.target}</span>`;

      let noticeHtml = '';
      if (p.designationNotice) noticeHtml += renderNoticeLink('지정', p.designationNotice);
      if (p.liftNotice) noticeHtml += renderNoticeLink('해제', p.liftNotice);

      return `<div class="rr-row">
        <span class="rr-period">${period}</span>
        ${p.scope ? `<span class="rr-scope">${p.scope}</span>` : ''}
        ${badges ? `<span class="rr-badges">${badges}</span>` : ''}
        ${noticeHtml ? `<p class="rr-notice">${noticeHtml}</p>` : ''}
        ${p.note ? `<p class="rr-note">${p.note}</p>` : ''}
      </div>`;
    }).join('');
  }

  function renderNoticeLink(label, noticeText) {
    // noticeText: "국토교통부공고 제2025-1223호(2025.10.16)" 형태
    // clientNoticeMap 키와 매칭
    for (const [id, info] of Object.entries(clientNoticeMap)) {
      if (noticeText.includes(id.replace('국토교통부공고 ', ''))) {
        if (info.file) {
          const ext = info.file.split('.').pop().toUpperCase();
          return `${label}: <a href="${info.file}" target="_blank" rel="noopener" download>${noticeText}</a> <span class="rr-badge" style="font-size:0.55rem">${ext}</span> `;
        }
      }
    }
    return `${label}: ${noticeText} `;
  }

  function fmtD(d) { return d.replace(/-/g, '.'); }

  input.addEventListener('input', (e) => search(e.target.value));

  // URL 쿼리로 초기 검색
  const params = new URLSearchParams(window.location.search);
  const initQ = params.get('q');
  if (initQ) {
    input.value = initQ;
    search(initQ);
  }
</script>
