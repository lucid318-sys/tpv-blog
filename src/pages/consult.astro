---
import Base from "../layouts/Base.astro";
---
<Base title="상담 안내">
  <main class="main">
    <h1 class="page-title">1:1 맞춤 세무 상담</h1>
    <p class="desc">
      더프라이빗택스에서 부동산 세금 전문 세무사와 함께<br />
      양도세·상속세·증여세·취득세까지 맞춤 상담을 받아보세요.
    </p>
    <a href="https://pf.kakao.com/_dcihX/chat" target="_blank" rel="noopener" class="btn">
      카카오톡 상담 신청
    </a>
  </main>
</Base>

<style>
  .main {
    max-width: 720px;
    margin: 0 auto;
    padding: 4rem 1.5rem;
    text-align: center;
  }
  .page-title {
    font-family: 'SUIT Variable', 'Pretendard', sans-serif;
    font-size: 1.6rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
  }
  .desc {
    font-size: 1rem;
    color: #666;
    line-height: 1.8;
    margin-bottom: 2rem;
  }
  .btn {
    display: inline-block;
    background: var(--terracotta);
    color: #fff;
    font-weight: 700;
    padding: 0.85rem 2rem;
    border-radius: 8px;
    font-size: 1rem;
    transition: opacity 0.2s;
  }
  .btn:hover {
    opacity: 0.9;
  }
</style>
