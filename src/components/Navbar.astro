---
---
<nav class="navbar">
  <div class="nav-inner">
    <div class="nav-brand">
      <a href="/" class="nav-logo">더프라이빗택스</a>
      <span class="nav-sub">세무사 허혜주</span>
    </div>

    <button class="hamburger" id="hamburger" aria-label="메뉴" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>

    <ul class="nav-menu" id="nav-menu">
      <li class="nav-search-mobile"><a href="/search/" class="nav-link">검색</a></li>
      <li class="has-dropdown">
        <button class="nav-link dropdown-trigger">세금 이야기<span class="arrow">▾</span></button>
        <ul class="dropdown">
          <li><a href="/category/chwideuk/">취득세</a></li>
          <li><a href="/category/yangdo/">양도소득세</a></li>
          <li><a href="/category/jeungyeo/">증여세</a></li>
          <li><a href="/category/sangsok/">상속세</a></li>
          <li><a href="/category/etc/">기타</a></li>
        </ul>
      </li>
      <li class="has-dropdown">
        <button class="nav-link dropdown-trigger">서식·자료<span class="arrow">▾</span></button>
        <ul class="dropdown">
          <li><a href="/resources/#forms">서식</a></li>
          <li><a href="/resources/#policy">정책·대책</a></li>
        </ul>
      </li>
      <li><a href="/consult/" class="nav-link">상담 안내</a></li>
      <li><a href="/about/" class="nav-link">세무사 소개</a></li>
      <li class="nav-search-desktop">
        <a href="/search/" class="nav-link search-icon" aria-label="검색">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </a>
      </li>
    </ul>
  </div>
</nav>

<style>
  .navbar {
    background: var(--dark-brown);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .nav-inner {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
  }
  .nav-brand {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }
  .nav-logo {
    font-family: 'Noto Serif KR', serif;
    font-size: 1.2rem;
    font-weight: 700;
    color: #fff;
  }
  .nav-sub {
    font-size: 0.75rem;
    color: var(--terracotta);
  }

  /* Search visibility */
  .nav-search-mobile { display: none; }
  .search-icon {
    display: flex;
    align-items: center;
    padding: 0.5rem;
  }

  /* Menu */
  .nav-menu {
    display: flex;
    list-style: none;
    gap: 0.25rem;
    align-items: center;
  }
  .nav-link {
    background: none;
    border: none;
    font-family: 'Pretendard', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--cream);
    padding: 0.5rem 0.75rem;
    cursor: pointer;
    border-radius: 6px;
    transition: background 0.15s;
  }
  .nav-link:hover {
    background: rgba(255,255,255,0.1);
  }

  /* Arrow indicator */
  .arrow {
    font-size: 0.7rem;
    margin-left: 0.3rem;
  }

  /* Dropdown */
  .has-dropdown {
    position: relative;
  }
  .dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    background: var(--dark-brown);
    min-width: 150px;
    border-radius: 0 0 8px 8px;
    padding: 0.4rem 0;
    box-shadow: 0 4px 16px rgba(0,0,0,0.25);
    list-style: none;
  }
  .has-dropdown:hover .dropdown {
    display: block;
  }
  .dropdown li a {
    display: block;
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
    color: var(--cream);
    transition: background 0.15s;
  }
  .dropdown li a:hover {
    background: rgba(255,255,255,0.1);
  }

  /* Hamburger */
  .hamburger {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    flex-direction: column;
    gap: 5px;
  }
  .hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--cream);
    border-radius: 1px;
    transition: transform 0.2s, opacity 0.2s;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .hamburger {
      display: flex;
    }
    .nav-search-mobile { display: list-item; }
    .nav-search-desktop { display: none; }
    .nav-menu {
      display: none;
      position: absolute;
      top: 60px;
      left: 0;
      right: 0;
      background: var(--dark-brown);
      flex-direction: column;
      padding: 0.5rem 0;
      gap: 0;
      box-shadow: 0 4px 16px rgba(0,0,0,0.25);
    }
    .nav-menu.open {
      display: flex;
    }
    .nav-menu > li {
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .nav-menu > li:last-child {
      border-bottom: none;
    }
    .nav-link {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      text-align: left;
      padding: 0.85rem 1.5rem;
      border-radius: 0;
    }
    .has-dropdown {
      position: static;
    }
    .has-dropdown:hover .dropdown {
      display: none;
    }
    .has-dropdown.open .dropdown {
      display: flex;
      flex-direction: column;
    }
    .dropdown {
      position: static;
      box-shadow: none;
      border-radius: 0;
      padding: 0.25rem 0 0.25rem 2rem;
      background: transparent;
      border-left: 2px solid var(--terracotta);
      margin-left: 1.5rem;
    }
    .dropdown li a {
      padding: 0.4rem 1rem;
      font-size: 0.8rem;
    }
  }
</style>

<script>
  const hamburger = document.getElementById('hamburger')!;
  const menu = document.getElementById('nav-menu')!;

  hamburger.addEventListener('click', () => {
    const isOpen = menu.classList.toggle('open');
    hamburger.setAttribute('aria-expanded', String(isOpen));
  });

  function updateArrow(el: Element, open: boolean) {
    const arrow = el.querySelector('.arrow');
    if (arrow) arrow.textContent = open ? '▴' : '▾';
  }

  document.querySelectorAll('.dropdown-trigger').forEach((btn) => {
    btn.addEventListener('click', () => {
      if (window.innerWidth <= 768) {
        const parent = btn.closest('.has-dropdown')!;
        document.querySelectorAll('.has-dropdown.open').forEach((el) => {
          if (el !== parent) {
            el.classList.remove('open');
            updateArrow(el, false);
          }
        });
        const isOpen = parent.classList.toggle('open');
        updateArrow(parent, isOpen);
      }
    });
  });
</script>
