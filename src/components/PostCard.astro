---
interface Props {
  slug: string;
  title: string;
  date: string;
  category: "yangdo" | "sangsok" | "jeungyeo" | "etc";
  type?: "column" | "case";
  summary: string;
}
const { slug, title, date, category, type, summary } = Astro.props;
const categoryLabels: Record<string, string> = {
  yangdo: "양도세",
  sangsok: "상속세",
  jeungyeo: "증여세",
  etc: "기타",
};
const catLabel = categoryLabels[category] ?? category;
---
<a href={`/blog/${slug}/`} class="card">
  <div class="meta">
    <span class={`badge ${category}`}>{catLabel}</span>
    {type === "case" && <span class="badge-type">사례</span>}
    <time>{date}</time>
  </div>
  <h2 class="title">{title}</h2>
  <p class="summary">{summary}</p>
</a>

<style>
  .card {
    display: block;
    background: #fff;
    border-radius: 12px;
    padding: 1.5rem;
    transition: box-shadow 0.2s;
  }
  .card:hover {
    box-shadow: 0 4px 20px rgba(44,33,23,0.1);
  }
  .meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .badge {
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
  }
  .badge.yangdo {
    background: var(--dark-brown);
    color: var(--cream);
  }
  .badge.sangsok {
    background: #5B7A5E;
    color: #fff;
  }
  .badge.jeungyeo {
    background: var(--terracotta);
    color: #fff;
  }
  .badge.etc {
    background: #888;
    color: #fff;
  }
  .badge-type {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.15rem 0.45rem;
    border-radius: 3px;
    border: 1.2px solid var(--dark-brown);
    color: var(--dark-brown);
    background: transparent;
  }
  time {
    font-size: 0.8rem;
    color: #999;
  }
  .title {
    font-family: 'Noto Serif KR', serif;
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    line-height: 1.5;
  }
  .summary {
    font-size: 0.9rem;
    color: #666;
    line-height: 1.6;
  }
</style>
